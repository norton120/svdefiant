#!/usr/bin/env bash
#
# Create / update / close refit tasks. Wraps `gh` so issues land in the
# repo with the right labels and as items on project #4 in one call.
#
# Usage:
#   bin/refit-task create <title> [options]
#   bin/refit-task update <issue#>  [options]
#   bin/refit-task close  <issue#>  [--reason completed|wontfix]
#
# Options (single-value dims replace any existing label in that dim on update;
# location is multi-value and replaces the full set when --location is given):
#   -p, --priority {p0|p1|p2|p3}
#   -s, --system   {electrical|rigging|sails|plumbing|engine|nav|hull|interior|ground-tackle|safety}
#   -l, --location <name,name,...>   from {indoors|on-deck|aloft|underwater|dockside-only|underway-ok}
#   -e, --energy   {couch|light|moderate|heavy}
#   -w, --weather  {any|dry|calm|warm}
#   -t, --time     {lt-1hr|half-day|full-day|multi-day}
#       --blocked-parts        add blocked:parts
#       --no-blocked-parts     remove blocked:parts (update only)
#   -b, --body <text>
#       --body-file <path>

set -euo pipefail

REPO="norton120/svdefiant"
PROJECT_NUMBER=4
PROJECT_OWNER="@me"

PRIORITIES=(p0 p1 p2 p3)
SYSTEMS=(electrical rigging sails plumbing engine nav hull interior ground-tackle safety)
LOCATIONS=(indoors on-deck aloft underwater dockside-only underway-ok)
ENERGIES=(couch light moderate heavy)
WEATHERS=(any dry calm warm)
TIMES=(lt-1hr half-day full-day multi-day)

die() { echo "error: $*" >&2; exit 1; }

usage() { sed -n '3,21p' "$0" | sed 's/^# \?//'; exit "${1:-0}"; }

contains() {
  local needle=$1; shift
  for x in "$@"; do [[ $x == "$needle" ]] && return 0; done
  return 1
}

validate() {
  local name=$1 value=$2; shift 2
  contains "$value" "$@" || die "invalid --$name '$value'; expected one of: $*"
}

PRIORITY=""; SYSTEM=""; LOCATION=""; ENERGY=""; WEATHER=""; TIME_=""
BLOCKED_PARTS=""   # "" unset, "add", "remove"
BODY=""; BODY_FILE=""

parse_opts() {
  while (( $# )); do
    case $1 in
      -p|--priority)       PRIORITY=$2; shift 2;;
      -s|--system)         SYSTEM=$2; shift 2;;
      -l|--location)       LOCATION=$2; shift 2;;
      -e|--energy)         ENERGY=$2; shift 2;;
      -w|--weather)        WEATHER=$2; shift 2;;
      -t|--time)           TIME_=$2; shift 2;;
      --blocked-parts)     BLOCKED_PARTS="add"; shift;;
      --no-blocked-parts)  BLOCKED_PARTS="remove"; shift;;
      -b|--body)           BODY=$2; shift 2;;
      --body-file)         BODY_FILE=$2; shift 2;;
      -h|--help)           usage 0;;
      *) die "unknown option: $1";;
    esac
  done

  [[ -n $PRIORITY ]] && validate priority "$PRIORITY" "${PRIORITIES[@]}"
  [[ -n $SYSTEM   ]] && validate system   "$SYSTEM"   "${SYSTEMS[@]}"
  [[ -n $ENERGY   ]] && validate energy   "$ENERGY"   "${ENERGIES[@]}"
  [[ -n $WEATHER  ]] && validate weather  "$WEATHER"  "${WEATHERS[@]}"
  [[ -n $TIME_    ]] && validate time     "$TIME_"    "${TIMES[@]}"
  if [[ -n $LOCATION ]]; then
    IFS=, read -r -a _locs <<<"$LOCATION"
    for l in "${_locs[@]}"; do validate location "$l" "${LOCATIONS[@]}"; done
  fi

  if [[ -n $BODY && -n $BODY_FILE ]]; then die "use --body or --body-file, not both"; fi
}

# Compose the full label set this invocation specifies (only set dims).
specified_labels() {
  local out=()
  [[ -n $PRIORITY ]] && out+=("$PRIORITY")
  [[ -n $SYSTEM   ]] && out+=("sys:$SYSTEM")
  [[ -n $ENERGY   ]] && out+=("energy:$ENERGY")
  [[ -n $WEATHER  ]] && out+=("weather:$WEATHER")
  [[ -n $TIME_    ]] && out+=("time:$TIME_")
  if [[ -n $LOCATION ]]; then
    IFS=, read -r -a _locs <<<"$LOCATION"
    for l in "${_locs[@]}"; do out+=("loc:$l"); done
  fi
  [[ $BLOCKED_PARTS == "add" ]] && out+=("blocked:parts")
  printf '%s\n' "${out[@]}"
}

cmd_create() {
  local title=${1:-}; [[ -n $title ]] || die "create requires a <title>"
  shift || true
  parse_opts "$@"

  local body_arg=()
  if   [[ -n $BODY_FILE ]]; then body_arg=(--body-file "$BODY_FILE")
  elif [[ -n $BODY      ]]; then body_arg=(--body "$BODY")
  else                            body_arg=(--body "")
  fi

  local label_args=()
  while IFS= read -r l; do label_args+=(--label "$l"); done < <(specified_labels)

  local url
  url=$(gh issue create --repo "$REPO" --title "$title" "${body_arg[@]}" ${label_args[@]+"${label_args[@]}"})
  echo "created: $url"
  gh project item-add "$PROJECT_NUMBER" --owner "$PROJECT_OWNER" --url "$url" >/dev/null
  echo "added to project #$PROJECT_NUMBER"
}

cmd_update() {
  local num=${1:-}; [[ -n $num ]] || die "update requires an <issue#>"
  shift || true
  parse_opts "$@"

  # current labels + project membership in one fetch
  local view_json
  view_json=$(gh issue view "$num" --repo "$REPO" --json labels,projectItems,url)
  local current=()
  while IFS= read -r line; do current+=("$line"); done \
    < <(jq -r '.labels[].name' <<<"$view_json")
  local in_project issue_url
  in_project=$(jq '.projectItems | length' <<<"$view_json")
  issue_url=$(jq -r '.url' <<<"$view_json")

  local to_add=() to_remove=()

  # single-value dims: if specified, remove any current label in that dim, add the new one
  _replace_dim() {
    local prefix=$1 new=$2
    [[ -z $new ]] && return
    local need_add=1
    for c in ${current[@]+"${current[@]}"}; do
      if [[ $c == ${prefix}* ]]; then
        if [[ $c == "$new" ]]; then
          need_add=0
        else
          to_remove+=("$c")
        fi
      fi
    done
    (( need_add )) && to_add+=("$new")
    return 0
  }
  _replace_dim "p"        "$PRIORITY"
  _replace_dim "sys:"     "${SYSTEM:+sys:$SYSTEM}"
  _replace_dim "energy:"  "${ENERGY:+energy:$ENERGY}"
  _replace_dim "weather:" "${WEATHER:+weather:$WEATHER}"
  _replace_dim "time:"    "${TIME_:+time:$TIME_}"

  # location: replace whole set, but skip no-ops
  if [[ -n $LOCATION ]]; then
    IFS=, read -r -a _locs <<<"$LOCATION"
    local new_locs=()
    for l in "${_locs[@]}"; do new_locs+=("loc:$l"); done
    for c in ${current[@]+"${current[@]}"}; do
      if [[ $c == loc:* ]]; then
        local keep=0
        for n in ${new_locs[@]+"${new_locs[@]}"}; do
          [[ $c == "$n" ]] && { keep=1; break; }
        done
        (( keep )) || to_remove+=("$c")
      fi
    done
    for n in ${new_locs[@]+"${new_locs[@]}"}; do
      local has=0
      for c in ${current[@]+"${current[@]}"}; do
        [[ $c == "$n" ]] && { has=1; break; }
      done
      (( has )) || to_add+=("$n")
    done
  fi

  # blocked:parts: only act if state changes
  local has_bp=0
  for c in ${current[@]+"${current[@]}"}; do
    [[ $c == "blocked:parts" ]] && { has_bp=1; break; }
  done
  case $BLOCKED_PARTS in
    add)    (( has_bp )) || to_add+=("blocked:parts");;
    remove) (( has_bp )) && to_remove+=("blocked:parts");;
  esac

  local edit_args=()
  for l in ${to_add[@]+"${to_add[@]}"};       do edit_args+=(--add-label    "$l"); done
  for l in ${to_remove[@]+"${to_remove[@]}"}; do edit_args+=(--remove-label "$l"); done

  if [[ -n $BODY_FILE ]]; then edit_args+=(--body-file "$BODY_FILE")
  elif [[ -n $BODY    ]]; then edit_args+=(--body      "$BODY")
  fi

  if (( ${#edit_args[@]} == 0 )); then
    echo "no label changes"
  else
    gh issue edit "$num" --repo "$REPO" "${edit_args[@]}" >/dev/null
    echo "updated #$num"
    if (( ${#to_add[@]}    )); then echo "  + ${to_add[*]}";    fi
    if (( ${#to_remove[@]} )); then echo "  - ${to_remove[*]}"; fi
  fi

  if (( in_project == 0 )); then
    gh project item-add "$PROJECT_NUMBER" --owner "$PROJECT_OWNER" --url "$issue_url" >/dev/null
    echo "  added to project #$PROJECT_NUMBER"
  fi
}

cmd_close() {
  local num=${1:-}; [[ -n $num ]] || die "close requires an <issue#>"
  shift || true
  local reason=""
  while (( $# )); do
    case $1 in
      --reason) reason=$2; shift 2;;
      *) die "unknown option: $1";;
    esac
  done
  local args=()
  [[ -n $reason ]] && args+=(--reason "$reason")
  gh issue close "$num" --repo "$REPO" "${args[@]}"
}

case ${1:-} in
  create) shift; cmd_create "$@";;
  update) shift; cmd_update "$@";;
  close)  shift; cmd_close  "$@";;
  ""|-h|--help) usage 0;;
  *) die "unknown command: $1 (try create|update|close)";;
esac
