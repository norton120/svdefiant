#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["tomli-w", "pillow", "pillow-heif"]
# ///
"""defiant — operational CLI for the S/V Defiant agent stack.

Subcommands:
  state    boat state (location, mode) — Home Assistant canonical, ~/.defiant/state-cache.toml fallback
  inbox    SES inbound mail (read + ack so the same email isn't reprocessed)
  task     GitHub issues + Project v2
  wiki     local wiki search + edit (auto-clones on first use)
  weather  marine weather + tides (auto when underway)
  calendar day-level events the agent should respect when scheduling

Cache, ack, calendar, and wiki files live under DEFIANT_HOME (default: ~/.defiant).
HA endpoint: HA_URL env (default http://homeassistant.local:8123),
HA token: HOME_ASSISTANT_ACCESS_TOKEN env (or .env in repo root).
"""
from __future__ import annotations

import argparse
import json
import math
import os
import re
import subprocess
import sys
import tomllib
import urllib.error
import urllib.request
from datetime import datetime, timedelta, timezone
from pathlib import Path
from urllib.parse import urlencode

import tomli_w

DEFIANT_HOME = Path(os.environ.get("DEFIANT_HOME", Path.home() / ".defiant"))
STATE_CACHE = DEFIANT_HOME / "state-cache.toml"
INBOX_STATE_FILE = DEFIANT_HOME / "inbox-state.json"
CALENDAR_FILE = DEFIANT_HOME / "calendar.json"

REPO_ROOT = Path(__file__).resolve().parent.parent
INBOX_SCRIPT = REPO_ROOT / "scripts" / "inbox.py"

HA_URL = os.environ.get("HA_URL", "http://homeassistant.local:8123").rstrip("/")
HA_TOKEN_ENV = "HOME_ASSISTANT_ACCESS_TOKEN"
HA_TIMEOUT = float(os.environ.get("HA_TIMEOUT", "5"))

MODE_VALUES = ("underway", "anchored", "moored", "docked", "hauled-out")

# Dotted state keys → HA entity. Sections (location, mode, underway) stay
# the same shape the CLI used to expose; the TOML is just no longer the
# source of truth.
STATE_ENTITIES: dict[str, str] = {
    "location.name": "input_text.defiant_location_name",
    "location.lat":  "input_number.defiant_latitude",
    "location.lon":  "input_number.defiant_longitude",
    "mode.status":   "input_select.defiant_mode",
    "underway.destination": "input_text.defiant_destination",
    "underway.dest_lat":    "input_number.defiant_destination_latitude",
    "underway.dest_lon":    "input_number.defiant_destination_longitude",
    "underway.eta":         "input_datetime.defiant_eta",
}

# (service, payload-key) per HA helper domain.
_ENTITY_WRITE: dict[str, tuple[str, str]] = {
    "input_text":     ("set_value",     "value"),
    "input_number":   ("set_value",     "value"),
    "input_select":   ("select_option", "option"),
    "input_datetime": ("set_datetime",  "datetime"),
}

# Lat/lon are auto-fed by Signal K (~60s cadence) via
# automation.defiant_sync_signal_k_position_to_helpers; manual writes get
# overwritten unless SK is offline. Warn but allow.
_SK_OVERWRITTEN_KEYS = {"location.lat", "location.lon"}

# GitHub: cached so the agent never has to know about node IDs.
GH_REPO = "norton120/svdefiant"
GH_REPO_OWNER, GH_REPO_NAME = GH_REPO.split("/")
GH_PROJECT_NUMBER = 4
GH_PROJECT_OWNER = "@me"
GH_PROJECT_ID = "PVT_kwHOAGJGHM4BVufn"
GH_ITERATION_FIELD_ID = "PVTIF_lAHOAGJGHM4BVufnzhRaGt0"
# Project field "Target date" — used as the per-issue scheduled day.
GH_DAY_FIELD_ID = "PVTF_lAHOAGJGHM4BVufnzhRak3E"

# Task label dimensions. Single-value dims replace any prior label in the same
# dim on update; `loc` is multi-value and replaces the full set when given.
LABEL_PRIORITIES = ("p0", "p1", "p2", "p3")
LABEL_SYSTEMS = (
    "electrical", "rigging", "sails", "plumbing", "engine",
    "nav", "hull", "interior", "ground-tackle", "safety",
)
LABEL_LOCATIONS = ("indoors", "on-deck", "aloft", "underwater",
                   "dockside-only", "underway-ok")
LABEL_ENERGIES = ("couch", "light", "moderate", "heavy")
LABEL_WEATHERS = ("any", "dry", "calm", "warm")
LABEL_TIMES = ("lt-1hr", "half-day", "full-day", "multi-day")

# Dotted-key → validator. tuple = enum, type = coerce, "iso_datetime" = parse check.
SCHEMA: dict[str, object] = {
    "location.name": str,
    "location.lat": float,
    "location.lon": float,
    "mode.status": MODE_VALUES,
    "underway.destination": str,
    "underway.dest_lat": float,
    "underway.dest_lon": float,
    "underway.eta": "iso_datetime",
}

WATCHED_SECTIONS = ("location", "mode")


# --- helpers ---------------------------------------------------------------

def now_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_duration(s: str) -> timedelta:
    m = re.fullmatch(r"(\d+)([dhm])", s)
    if not m:
        die(f"bad duration {s!r}; use NNd, NNh, NNm")
    n, unit = int(m.group(1)), m.group(2)
    return {"d": timedelta(days=n), "h": timedelta(hours=n), "m": timedelta(minutes=n)}[unit]


def die(msg: str, code: int = 1) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


def atomic_write_bytes(path: Path, data: bytes) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_bytes(data)
    os.replace(tmp, path)


# --- state -----------------------------------------------------------------

def _ha_token() -> str | None:
    t = os.environ.get(HA_TOKEN_ENV)
    if t:
        return t
    env = REPO_ROOT / ".env"
    if env.exists():
        for line in env.read_text().splitlines():
            if line.startswith(f"{HA_TOKEN_ENV}="):
                return line.split("=", 1)[1].strip().strip('"').strip("'")
    return None


def _ha_request(method: str, path: str, body: dict | None = None) -> dict | list | None:
    token = _ha_token()
    if not token:
        raise RuntimeError(f"{HA_TOKEN_ENV} not set (env or repo .env)")
    req = urllib.request.Request(
        f"{HA_URL}{path}",
        data=json.dumps(body).encode() if body is not None else None,
        method=method,
        headers={"Authorization": f"Bearer {token}", "Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=HA_TIMEOUT) as resp:
        raw = resp.read().decode() or "null"
        return json.loads(raw)


def _ha_get_state(entity_id: str) -> dict | None:
    try:
        return _ha_request("GET", f"/api/states/{entity_id}")  # type: ignore[return-value]
    except urllib.error.HTTPError as e:
        if e.code == 404:
            return None
        raise


def _ha_call_service(domain: str, service: str, body: dict) -> None:
    _ha_request("POST", f"/api/services/{domain}/{service}", body)


def _normalize_value(eid: str, ha: dict) -> object | None:
    """HA state → python value, or None for sentinel/unset values.

    `unavailable` is always treated as unset. `unknown` is unset for
    input_text and input_datetime (HA's default for never-set values), but
    NOT for input_select where `unknown` is an explicit option in the
    defiant_mode enum.
    """
    raw = ha.get("state")
    if raw in (None, "unavailable", ""):
        return None
    domain = eid.split(".", 1)[0]
    if domain in ("input_text", "input_datetime") and raw == "unknown":
        return None
    if domain == "input_number":
        try:
            return float(raw)
        except ValueError:
            return None
    if domain == "input_datetime":
        # HA returns "YYYY-MM-DD HH:MM:SS" (local-naive). Surface as ISO-Z so
        # downstream consumers can fromisoformat it.
        try:
            dt = datetime.strptime(raw, "%Y-%m-%d %H:%M:%S")
            return dt.strftime("%Y-%m-%dT%H:%M:%SZ")
        except ValueError:
            return raw
    return raw


def _save_state_cache(state: dict) -> None:
    try:
        payload = {**state, "_cached_at": now_iso()}
        atomic_write_bytes(STATE_CACHE, tomli_w.dumps(payload).encode())
    except Exception as e:
        # Cache write failures shouldn't block reads — just stderr-warn.
        print(f"warning: state cache write failed: {e}", file=sys.stderr)


def _load_state_cache() -> dict | None:
    if not STATE_CACHE.exists():
        return None
    try:
        with STATE_CACHE.open("rb") as f:
            return tomllib.load(f)
    except Exception:
        return None


def _load_state_from_ha() -> dict:
    out: dict = {}
    last_per_section: dict[str, str] = {}
    for dotted, eid in STATE_ENTITIES.items():
        section, _, field = dotted.partition(".")
        ha = _ha_get_state(eid)
        if ha is None:
            continue
        val = _normalize_value(eid, ha)
        if val is None:
            continue
        out.setdefault(section, {})[field] = val
        last = ha.get("last_updated")
        if last and (section not in last_per_section or last < last_per_section[section]):
            last_per_section[section] = last
    for sec, lu in last_per_section.items():
        out[sec]["updated"] = lu
    return out


def load_state() -> dict:
    """Return state dict, preferring HA. Falls back to cache (with stderr
    warning) on HA error. Returns {} if both are unavailable — write commands
    still run, read commands just see no data."""
    try:
        state = _load_state_from_ha()
        _save_state_cache(state)
        return state
    except Exception as e:
        cache = _load_state_cache()
        if cache:
            cached_at = cache.pop("_cached_at", "?")
            print(
                f"# WARNING: HA unreachable ({e}); serving cached state from {cached_at}",
                file=sys.stderr,
            )
            return cache
        print(f"warning: HA unreachable ({e}) and no cache available", file=sys.stderr)
        return {}


def coerce_for_set(dotted: str, raw: str) -> object:
    spec = SCHEMA.get(dotted)
    if spec is None:
        die(f"unknown key {dotted!r}; valid keys:\n  " + "\n  ".join(sorted(SCHEMA)))
    if isinstance(spec, tuple):
        if raw not in spec:
            die(f"{dotted}: must be one of {', '.join(spec)}")
        return raw
    if spec is float:
        try:
            return float(raw)
        except ValueError:
            die(f"{dotted}: must be a number")
    if spec == "iso_datetime":
        try:
            datetime.fromisoformat(raw.replace("Z", "+00:00"))
        except ValueError:
            die(f"{dotted}: must be ISO datetime (e.g. 2026-04-30T18:00:00Z)")
        return raw
    return raw


def cmd_state_show(args, state):
    if not state:
        print("(state file is empty)")
        return
    json.dump(state, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")


def cmd_state_get(args, state):
    section, _, field = args.key.partition(".")
    sec = state.get(section, {})
    if not field:
        json.dump(sec, sys.stdout, indent=2, default=str)
        sys.stdout.write("\n")
        return
    val = sec.get(field, "")
    if isinstance(val, (dict, list)):
        json.dump(val, sys.stdout, indent=2, default=str)
        sys.stdout.write("\n")
    else:
        print(val)


def cmd_state_set(args, state):
    coerced = coerce_for_set(args.key, args.value)
    eid = STATE_ENTITIES.get(args.key)
    if not eid:
        die(f"key {args.key!r} has no HA entity mapping")

    if args.key in _SK_OVERWRITTEN_KEYS:
        print(
            f"warning: {args.key} is auto-fed by Signal K (~60s cadence). "
            f"Manual value will stick only if SK is offline or the sync "
            f"automation is disabled.",
            file=sys.stderr,
        )

    domain = eid.split(".", 1)[0]
    service, payload_key = _ENTITY_WRITE[domain]
    payload_value: object = coerced
    if domain == "input_datetime":
        # set_datetime accepts "YYYY-MM-DD HH:MM:SS"; coerce_for_set already
        # validated ISO format.
        try:
            dt = datetime.fromisoformat(str(coerced).replace("Z", "+00:00"))
            payload_value = dt.strftime("%Y-%m-%d %H:%M:%S")
        except ValueError:
            die(f"{args.key}: could not parse datetime {coerced!r}")

    body = {"entity_id": eid, payload_key: payload_value}
    try:
        _ha_call_service(domain, service, body)
    except Exception as e:
        die(f"HA write failed for {eid}: {e}")
    print(f"set {args.key} = {args.value}")


def cmd_state_stale(args, state):
    max_age = parse_duration(args.max)
    now = datetime.now(timezone.utc)
    stale = []
    for section in WATCHED_SECTIONS:
        upd = state.get(section, {}).get("updated")
        if not upd:
            stale.append((section, "never set"))
            continue
        when = datetime.fromisoformat(upd.replace("Z", "+00:00"))
        if now - when > max_age:
            age = now - when
            stale.append((section, f"updated {upd} ({age.days}d ago)"))
    if not stale:
        print("fresh")
        return
    for s, why in stale:
        print(f"stale: {s} ({why})", file=sys.stderr)
    sys.exit(1)


# --- inbox -----------------------------------------------------------------

def load_inbox_state() -> dict:
    if not INBOX_STATE_FILE.exists():
        return {"acked": {}}
    with INBOX_STATE_FILE.open() as f:
        s = json.load(f)
    s.setdefault("acked", {})
    return s


def save_inbox_state(s: dict) -> None:
    atomic_write_bytes(INBOX_STATE_FILE, json.dumps(s, indent=2).encode())


def msg_ids(m: dict) -> set[str]:
    """All identifiers we'll accept as matching this message."""
    out = set()
    if mid := m.get("message_id"):
        out.add(mid)
    if k := m.get("s3_key"):
        out.add(k)
    return out


def inbox_list_raw(since: str, from_pat: str | None, subject_pat: str | None) -> list[dict]:
    if not INBOX_SCRIPT.exists():
        die(f"missing {INBOX_SCRIPT} — is the repo intact?")
    cmd = [str(INBOX_SCRIPT), "list", "--since", since]
    if from_pat:
        cmd += ["--from", from_pat]
    if subject_pat:
        cmd += ["--subject", subject_pat]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        die(f"inbox.py failed:\n{r.stderr.strip()}")
    return json.loads(r.stdout)


def cmd_inbox_list(args):
    msgs = inbox_list_raw(args.since, args.from_pat, args.subject_pat)
    if args.unprocessed:
        acked = set(load_inbox_state()["acked"])
        msgs = [m for m in msgs if not (msg_ids(m) & acked)]
    json.dump(msgs, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")


def cmd_inbox_get(args):
    if not INBOX_SCRIPT.exists():
        die(f"missing {INBOX_SCRIPT}")
    r = subprocess.run([str(INBOX_SCRIPT), "get", args.id])
    sys.exit(r.returncode)


def cmd_inbox_ack(args):
    s = load_inbox_state()
    s["acked"][args.id] = {"acked_at": now_iso(), "note": args.note or ""}
    save_inbox_state(s)
    print(f"acked {args.id}")


def cmd_inbox_unack(args):
    s = load_inbox_state()
    if args.id not in s["acked"]:
        die(f"not in acked: {args.id}")
    del s["acked"][args.id]
    save_inbox_state(s)
    print(f"unacked {args.id}")


# --- task ------------------------------------------------------------------

def gh(*args: str, parse_json: bool = False) -> object:
    r = subprocess.run(["gh", *args], capture_output=True, text=True)
    if r.returncode != 0:
        die(f"gh {' '.join(args[:2])}… failed: {r.stderr.strip() or 'unknown error'}")
    out = r.stdout.strip()
    if parse_json:
        return json.loads(out) if out else None
    return out


def gh_graphql(query: str, **fields: object) -> dict:
    """Run a graphql query/mutation; return the `data` payload."""
    cmd = ["api", "graphql", "-f", f"query={query}"]
    for k, v in fields.items():
        flag = "-F" if isinstance(v, (int, bool)) else "-f"
        cmd += [flag, f"{k}={v}"]
    return gh(*cmd, parse_json=True)["data"]


def flatten_labels(label_objs: list) -> list[str]:
    """gh returns labels as objects; agent wants names."""
    return [l["name"] for l in label_objs]


def specified_labels(args) -> list[str]:
    """Compose the label set this invocation specifies (only set dims)."""
    out: list[str] = []
    if args.priority:
        out.append(args.priority)
    if args.system:
        out.append(f"sys:{args.system}")
    if args.energy:
        out.append(f"energy:{args.energy}")
    if args.weather:
        out.append(f"weather:{args.weather}")
    if args.time_:
        out.append(f"time:{args.time_}")
    if args.location:
        out += [f"loc:{l}" for l in args.location.split(",")]
    if args.blocked_parts == "add":
        out.append("blocked:parts")
    return out


def diff_labels(current: list[str], args) -> tuple[list[str], list[str]]:
    """Compute (to_add, to_remove) given current labels and update args."""
    to_add: list[str] = []
    to_remove: list[str] = []

    def replace_dim(prefix: str, new: str | None) -> None:
        if not new:
            return
        keep = False
        for c in current:
            if c.startswith(prefix):
                if c == new:
                    keep = True
                else:
                    to_remove.append(c)
        if not keep:
            to_add.append(new)

    # bare priority labels share no prefix beyond "p"; match on exact membership
    if args.priority:
        for c in current:
            if c in LABEL_PRIORITIES and c != args.priority:
                to_remove.append(c)
        if args.priority not in current:
            to_add.append(args.priority)

    replace_dim("sys:",     f"sys:{args.system}"     if args.system  else None)
    replace_dim("energy:",  f"energy:{args.energy}"  if args.energy  else None)
    replace_dim("weather:", f"weather:{args.weather}" if args.weather else None)
    replace_dim("time:",    f"time:{args.time_}"     if args.time_   else None)

    if args.location:
        new_locs = {f"loc:{l}" for l in args.location.split(",")}
        for c in current:
            if c.startswith("loc:") and c not in new_locs:
                to_remove.append(c)
        for n in new_locs:
            if n not in current:
                to_add.append(n)

    if args.blocked_parts == "add" and "blocked:parts" not in current:
        to_add.append("blocked:parts")
    elif args.blocked_parts == "remove" and "blocked:parts" in current:
        to_remove.append("blocked:parts")

    return to_add, to_remove


def filter_schedulable(issues: list[dict], mode_status: str | None) -> list[dict]:
    """Drop issues that can't be done given the boat's current mode.

    - blocked:parts always excluded
    - loc:dockside-only excluded unless docked
    - when underway, only loc:underway-ok issues are kept
    """
    out = []
    for i in issues:
        labels = i["labels"]
        if "blocked:parts" in labels:
            continue
        if "loc:dockside-only" in labels and mode_status != "docked":
            continue
        if mode_status == "underway" and "loc:underway-ok" not in labels:
            continue
        out.append(i)
    return out


def cmd_task_list(args, state):
    if args.iteration:
        issues = _list_by_iteration(args)
    else:
        fields = "number,title,url,labels,milestone,state"
        if args.with_body:
            fields += ",body"
        cmd = ["issue", "list", "--repo", GH_REPO, "--state", "open",
               "--limit", str(args.limit), "--json", fields]
        if args.milestone:
            cmd += ["--milestone", args.milestone]
        for lbl in args.labels or []:
            cmd += ["--label", lbl]
        raw = gh(*cmd, parse_json=True)

        issues = []
        for r in raw:
            item = {
                "number": r["number"],
                "title": r["title"],
                "url": r["url"],
                "state": r["state"],
                "labels": flatten_labels(r["labels"]),
                "milestone": (r["milestone"] or {}).get("title"),
            }
            if args.with_body:
                item["body"] = r.get("body") or ""
            issues.append(item)

    if args.schedulable:
        mode_status = state.get("mode", {}).get("status")
        issues = filter_schedulable(issues, mode_status)

    json.dump(issues, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")


_PROJECT_ITEMS_QUERY = """
query($projectId: ID!, $cursor: String) {
  node(id: $projectId) {
    ... on ProjectV2 {
      items(first: 100, after: $cursor) {
        pageInfo { hasNextPage endCursor }
        nodes {
          id
          fieldValues(first: 30) {
            nodes {
              __typename
              ... on ProjectV2ItemFieldIterationValue {
                title iterationId
                field { ... on ProjectV2IterationField { id name } }
              }
              ... on ProjectV2ItemFieldSingleSelectValue {
                name
                field { ... on ProjectV2SingleSelectField { id name } }
              }
              ... on ProjectV2ItemFieldDateValue {
                date
                field { ... on ProjectV2Field { id name } }
              }
            }
          }
          content {
            __typename
            ... on Issue {
              number title url state body
              milestone { title }
              labels(first: 50) { nodes { name } }
            }
          }
        }
      }
    }
  }
}
"""


def _list_by_iteration(args) -> list[dict]:
    """List open issues whose project Iteration matches args.iteration."""
    iteration = _resolve_iteration(args.iteration)
    target_id = iteration["id"]
    label_set = set(args.labels or [])
    out: list[dict] = []
    cursor: str | None = None
    while True:
        kwargs: dict[str, object] = {"projectId": GH_PROJECT_ID}
        if cursor:
            kwargs["cursor"] = cursor
        data = gh_graphql(_PROJECT_ITEMS_QUERY, **kwargs)
        items = ((data.get("node") or {}).get("items") or {})
        for it in items.get("nodes", []):
            content = it.get("content") or {}
            if content.get("__typename") != "Issue":
                continue
            if content.get("state") != "OPEN":
                continue
            iter_val = None
            for fv in (it.get("fieldValues") or {}).get("nodes", []):
                f = fv.get("field") or {}
                if f.get("name") == "Iteration":
                    iter_val = fv.get("iterationId")
                    break
            if iter_val != target_id:
                continue
            labels = [l["name"] for l in content["labels"]["nodes"]]
            if label_set and not label_set.issubset(labels):
                continue
            milestone = (content.get("milestone") or {}).get("title")
            if args.milestone and milestone != args.milestone:
                continue
            entry = {
                "number": content["number"],
                "title": content["title"],
                "url": content["url"],
                "state": content["state"],
                "labels": labels,
                "milestone": milestone,
                "iteration": _field_value(it, "Iteration"),
                "day": _field_value(it, "Target date"),
                "project_status": _field_value(it, "Status"),
            }
            if args.with_body:
                entry["body"] = content.get("body") or ""
            out.append(entry)
        page = items.get("pageInfo") or {}
        if not page.get("hasNextPage"):
            break
        cursor = page.get("endCursor")
    return out


_SHOW_QUERY = """
query($number: Int!) {
  repository(owner: "%s", name: "%s") {
    issue(number: $number) {
      id title body url state
      milestone { title }
      labels(first: 50) { nodes { name } }
      projectItems(first: 10) {
        nodes {
          id
          project { id number title }
          fieldValues(first: 30) {
            nodes {
              __typename
              ... on ProjectV2ItemFieldIterationValue {
                title iterationId
                field { ... on ProjectV2IterationField { id name } }
              }
              ... on ProjectV2ItemFieldSingleSelectValue {
                name
                field { ... on ProjectV2SingleSelectField { id name } }
              }
              ... on ProjectV2ItemFieldDateValue {
                date
                field { ... on ProjectV2Field { id name } }
              }
            }
          }
        }
      }
    }
  }
}
""" % (GH_REPO_OWNER, GH_REPO_NAME)


def _project_item_for(issue_data: dict) -> dict | None:
    """Find the project item attached to OUR project, if any."""
    for item in issue_data.get("projectItems", {}).get("nodes", []):
        if item["project"]["id"] == GH_PROJECT_ID:
            return item
    return None


def _field_value(item: dict, field_name: str) -> str | None:
    for fv in item.get("fieldValues", {}).get("nodes", []):
        f = fv.get("field") or {}
        if f.get("name") != field_name:
            continue
        return fv.get("title") or fv.get("name") or fv.get("date")
    return None


def cmd_task_show(args):
    data = gh_graphql(_SHOW_QUERY, number=args.num)
    issue = (data.get("repository") or {}).get("issue")
    if not issue:
        die(f"issue #{args.num} not found")

    item = _project_item_for(issue)
    out = {
        "number": args.num,
        "id": issue["id"],
        "title": issue["title"],
        "url": issue["url"],
        "state": issue["state"],
        "body": issue["body"],
        "milestone": (issue["milestone"] or {}).get("title"),
        "labels": [l["name"] for l in issue["labels"]["nodes"]],
        "in_project": item is not None,
        "project_status": _field_value(item, "Status") if item else None,
        "iteration": _field_value(item, "Iteration") if item else None,
        "day": _field_value(item, "Target date") if item else None,
    }
    json.dump(out, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")


def _read_body(args) -> str | None:
    if args.body and args.body_file:
        die("use --body or --body-file, not both")
    if args.body_file:
        return Path(args.body_file).read_text()
    return args.body


def cmd_task_create(args):
    if not args.title:
        die("create requires <title>")
    body = _read_body(args) or ""
    cmd = ["issue", "create", "--repo", GH_REPO, "--title", args.title, "--body", body]
    for lbl in specified_labels(args):
        cmd += ["--label", lbl]
    url = gh(*cmd).strip().splitlines()[-1]
    print(f"created: {url}")
    # Use raw GraphQL (works with just the `project` scope) instead of
    # `gh project item-add`, which gh CLI tries to dispatch via its org-aware
    # codepath and demands `read:org` for.
    issue_num = int(url.rstrip("/").rsplit("/", 1)[-1])
    _ensure_project_item(issue_num)
    print(f"added to project #{GH_PROJECT_NUMBER}")


def cmd_task_update(args):
    view = gh("issue", "view", str(args.num), "--repo", GH_REPO,
              "--json", "labels,projectItems", parse_json=True)
    current = flatten_labels(view["labels"])
    in_project = any(p["title"] for p in view.get("projectItems", []))

    to_add, to_remove = diff_labels(current, args)

    edit_args = []
    for l in to_add:
        edit_args += ["--add-label", l]
    for l in to_remove:
        edit_args += ["--remove-label", l]
    body = _read_body(args)
    if body is not None:
        edit_args += ["--body", body]

    if not edit_args:
        print(f"#{args.num}: no changes")
    else:
        gh("issue", "edit", str(args.num), "--repo", GH_REPO, *edit_args)
        print(f"updated #{args.num}")
        if to_add:
            print(f"  + {' '.join(to_add)}")
        if to_remove:
            print(f"  - {' '.join(to_remove)}")

    if not in_project:
        _ensure_project_item(args.num)
        print(f"  added to project #{GH_PROJECT_NUMBER}")


def cmd_task_close(args):
    cmd = ["issue", "close", str(args.num), "--repo", GH_REPO]
    if args.reason:
        cmd += ["--reason", args.reason]
    gh(*cmd)
    print(f"closed #{args.num}")


_ITERATION_FIELD_QUERY = """
{
  node(id: "%s") {
    ... on ProjectV2IterationField {
      configuration {
        duration
        iterations { id title startDate duration }
        completedIterations { id title startDate duration }
      }
    }
  }
}
""" % GH_ITERATION_FIELD_ID


def _resolve_iteration(spec: str) -> dict:
    data = gh_graphql(_ITERATION_FIELD_QUERY)
    cfg = ((data.get("node") or {}).get("configuration")) or {}
    iterations = cfg.get("iterations") or []
    if not iterations:
        die("iteration field has no active iterations configured "
            "(open project settings, set a cadence)")

    iterations = sorted(iterations, key=lambda i: i["startDate"])

    if spec not in ("current", "next"):
        for it in iterations:
            if it["id"] == spec:
                return it
        for it in (cfg.get("completedIterations") or []):
            if it["id"] == spec:
                return it
        die(f"no iteration with id {spec!r}")

    today = datetime.now(timezone.utc).date()
    cur_idx = None
    for i, it in enumerate(iterations):
        start = datetime.fromisoformat(it["startDate"]).date()
        end = start + timedelta(days=it["duration"])
        if start <= today < end:
            cur_idx = i
            break
    if cur_idx is None:
        die("no iteration covers today; set a cadence on the iteration field")

    if spec == "current":
        return iterations[cur_idx]
    if cur_idx + 1 >= len(iterations):
        die("no `next` iteration configured beyond the current one")
    return iterations[cur_idx + 1]


_ISSUE_NODE_QUERY = """
query($number: Int!) {
  repository(owner: "%s", name: "%s") {
    issue(number: $number) {
      id
      projectItems(first: 10) {
        nodes { id project { id } }
      }
    }
  }
}
""" % (GH_REPO_OWNER, GH_REPO_NAME)


def _ensure_project_item(issue_num: int) -> str:
    """Return the project item ID for our project, adding to project if needed."""
    data = gh_graphql(_ISSUE_NODE_QUERY, number=issue_num)
    issue = (data.get("repository") or {}).get("issue")
    if not issue:
        die(f"issue #{issue_num} not found")
    for item in issue["projectItems"]["nodes"]:
        if item["project"]["id"] == GH_PROJECT_ID:
            return item["id"]
    mut = """
    mutation($projectId: ID!, $contentId: ID!) {
      addProjectV2ItemById(input: {projectId: $projectId, contentId: $contentId}) {
        item { id }
      }
    }
    """
    res = gh_graphql(mut, projectId=GH_PROJECT_ID, contentId=issue["id"])
    return res["addProjectV2ItemById"]["item"]["id"]


def cmd_task_iteration(args):
    chosen = sum(1 for x in (args.current, args.next, args.id) if x)
    if chosen != 1:
        die("specify exactly one of --current, --next, --id <iter-id>")
    spec = "current" if args.current else "next" if args.next else args.id
    iteration = _resolve_iteration(spec)

    item_id = _ensure_project_item(args.num)

    mut = """
    mutation($projectId: ID!, $itemId: ID!, $fieldId: ID!, $iterationId: String!) {
      updateProjectV2ItemFieldValue(input: {
        projectId: $projectId
        itemId: $itemId
        fieldId: $fieldId
        value: { iterationId: $iterationId }
      }) { projectV2Item { id } }
    }
    """
    gh_graphql(mut,
               projectId=GH_PROJECT_ID, itemId=item_id,
               fieldId=GH_ITERATION_FIELD_ID, iterationId=iteration["id"])
    print(f"assigned #{args.num} to {iteration['title']} (start {iteration['startDate']})")


def cmd_task_day(args):
    if bool(args.date) == bool(args.clear):
        die("specify either YYYY-MM-DD or --clear (not both, not neither)")
    item_id = _ensure_project_item(args.num)

    if args.clear:
        mut = """
        mutation($projectId: ID!, $itemId: ID!, $fieldId: ID!) {
          clearProjectV2ItemFieldValue(input: {
            projectId: $projectId
            itemId: $itemId
            fieldId: $fieldId
          }) { projectV2Item { id } }
        }
        """
        gh_graphql(mut, projectId=GH_PROJECT_ID, itemId=item_id,
                   fieldId=GH_DAY_FIELD_ID)
        print(f"cleared day on #{args.num}")
        return

    try:
        datetime.strptime(args.date, "%Y-%m-%d")
    except ValueError:
        die(f"date must be YYYY-MM-DD, got {args.date!r}")

    mut = """
    mutation($projectId: ID!, $itemId: ID!, $fieldId: ID!, $date: Date!) {
      updateProjectV2ItemFieldValue(input: {
        projectId: $projectId
        itemId: $itemId
        fieldId: $fieldId
        value: { date: $date }
      }) { projectV2Item { id } }
    }
    """
    gh_graphql(mut,
               projectId=GH_PROJECT_ID, itemId=item_id,
               fieldId=GH_DAY_FIELD_ID, date=args.date)
    print(f"set day on #{args.num} to {args.date}")


# --- calendar --------------------------------------------------------------
# Day-level events (sailing, traveling, etc.) that the agent should know about
# when scheduling. Stored locally because they're not work — they don't belong
# in the issue tracker.

def _parse_date(s: str) -> str:
    try:
        return datetime.strptime(s, "%Y-%m-%d").strftime("%Y-%m-%d")
    except ValueError:
        die(f"date must be YYYY-MM-DD, got {s!r}")


def _load_calendar() -> list[dict]:
    if not CALENDAR_FILE.exists():
        return []
    try:
        with CALENDAR_FILE.open() as f:
            entries = json.load(f)
    except Exception as e:
        die(f"calendar file unreadable ({CALENDAR_FILE}): {e}")
    if not isinstance(entries, list):
        die(f"calendar file must be a JSON list, got {type(entries).__name__}")
    return sorted(entries, key=lambda e: e.get("date", ""))


def _save_calendar(entries: list[dict]) -> None:
    entries = sorted(entries, key=lambda e: e.get("date", ""))
    atomic_write_bytes(CALENDAR_FILE, (json.dumps(entries, indent=2) + "\n").encode())


def cmd_calendar_add(args):
    date = _parse_date(args.date)
    entries = [e for e in _load_calendar() if e.get("date") != date]
    entries.append({"date": date, "label": args.label, "blocks": not args.soft})
    _save_calendar(entries)
    kind = "soft" if args.soft else "blocking"
    print(f"calendar: {date} = {args.label!r} ({kind})")


def cmd_calendar_remove(args):
    date = _parse_date(args.date)
    entries = _load_calendar()
    keep = [e for e in entries if e.get("date") != date]
    if len(keep) == len(entries):
        print(f"calendar: no event on {date}")
        return
    _save_calendar(keep)
    print(f"calendar: removed {date}")


def cmd_calendar_list(args):
    today = datetime.now(timezone.utc).date()
    start = datetime.strptime(args.from_, "%Y-%m-%d").date() if args.from_ else today
    end = datetime.strptime(args.to, "%Y-%m-%d").date() if args.to else (today + timedelta(days=7))
    out = [e for e in _load_calendar()
           if start <= datetime.strptime(e["date"], "%Y-%m-%d").date() <= end]
    json.dump(out, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")


# --- planner ---------------------------------------------------------------
# Builds data/planner.json from current-iteration issues + calendar events,
# in the shape the Hugo template at layouts/planner/single.html consumes.

PLANNER_DATA_FILE = REPO_ROOT / "data" / "planner.json"

# Display order for sys: lanes. Anything labelled sys:other ends up in "other".
PLANNER_LANE_ORDER = list(LABEL_SYSTEMS) + ["other"]


def _label_dim(labels: list[str], prefix: str) -> str | None:
    for l in labels:
        if l.startswith(prefix):
            return l[len(prefix):]
    return None


def _systems_for(labels: list[str]) -> list[str]:
    out = [l[len("sys:"):] for l in labels if l.startswith("sys:")]
    return out or ["other"]


def _primary_system(systems: list[str]) -> str:
    # First system in PLANNER_LANE_ORDER wins; falls back to first listed
    # so unknown sys: labels still land somewhere deterministic.
    for s in PLANNER_LANE_ORDER:
        if s in systems:
            return s
    return systems[0] if systems else "other"


def _priority_for(labels: list[str]) -> str | None:
    for p in LABEL_PRIORITIES:
        if p in labels:
            return p
    return None


def _day_label(d: datetime, today: datetime) -> str:
    delta = (d.date() - today.date()).days
    if delta == 0:
        return "Today"
    if delta == 1:
        return "Tomorrow"
    return d.strftime("%a %b %-d")


def _planner_issue(item: dict) -> dict:
    labels = item["labels"]
    return {
        "number": item["number"],
        "title": item["title"],
        "url": item["url"],
        "milestone": item.get("milestone"),
        "priority": _priority_for(labels),
        "systems": _systems_for(labels),
        "energy": _label_dim(labels, "energy:"),
        "weather": _label_dim(labels, "weather:"),
        "time": _label_dim(labels, "time:"),
        "locations": [l[len("loc:"):] for l in labels if l.startswith("loc:")],
        "blocked_parts": "blocked:parts" in labels,
        "project_status": item.get("project_status"),
        "day": item.get("day"),
    }


HAZARD_ICONS = {
    "small_craft_advisory":     "☠️",
    "special_marine_warning":   "⚠️",
    "marine_weather_statement": "⚠️",
    "gale_warning":             "🌬️",
    "storm_warning":            "⛈️",
    "hurricane_warning":        "🌀",
    "tropical_storm_warning":   "🌀",
}
HAZARD_TOOLTIPS = {
    "small_craft_advisory": "⛵",
}


def _planner_weather_icons(day: dict) -> list[str]:
    """Pick 1-3 icons summarising a day's weather for the planner header."""
    icons: list[str] = []
    for token in day.get("hazards") or []:
        ic = HAZARD_ICONS.get(token, "⚠️")
        if ic not in icons:
            icons.append(ic)
    if day.get("precip"):
        icons.append("🌧️")
    else:
        tmin, tmax = day.get("temp_f") or [None, None]
        if tmax is not None and tmax > 70 and (tmin is None or tmin >= 55):
            icons.append("☀️")
        else:
            icons.append("⛅")
    if (day.get("wind_kt_max") or 0) >= 18 and "🌧️" not in icons:
        icons.append("💨")
    return icons


def _planner_weather_for_window(state: dict, dates: list[str]) -> dict[str, dict]:
    """Best-effort: returns {YYYY-MM-DD: {icons, temp_label, wind_kt_max}}.
    Silently returns {} if location unset or any fetch fails."""
    loc = state.get("location") or {}
    lat, lon = loc.get("lat"), loc.get("lon")
    if lat is None or lon is None:
        return {}
    # NWS public forecast page for the point — renders active alerts up top + marine
    forecast_url = f"https://forecast.weather.gov/MapClick.php?lat={lat}&lon={lon}"
    today = datetime.now(timezone.utc).date()
    horizon = max((datetime.strptime(d, "%Y-%m-%d").date() - today).days
                  for d in dates) + 1
    if horizon <= 0:
        return {}
    horizon = min(horizon, 16)
    try:
        fc = fetch_forecast(lat, lon, horizon)
        marine = fetch_marine(lat, lon, horizon)
        alerts = fetch_alerts(lat, lon)
    except SystemExit:
        return {}
    daily = fc["daily"]
    waves = (marine or {}).get("daily", {}).get("wave_height_max") or [None] * len(daily["time"])
    out: dict[str, dict] = {}
    for i, date_ in enumerate(daily["time"]):
        if date_ not in dates:
            continue
        wind = daily["wind_speed_10m_max"][i] or 0
        gust = daily["wind_gusts_10m_max"][i] or 0
        tmax = daily["temperature_2m_max"][i]
        tmin = daily["temperature_2m_min"][i]
        precip = (daily["precipitation_sum"][i] or 0) >= 0.01
        wave_m = waves[i] if i < len(waves) else None
        wave_ft = round(wave_m * 3.28084, 1) if wave_m is not None else None
        day_alerts = alerts_for_day(alerts, date_)
        for a in day_alerts:
            a["url"] = forecast_url
        wind_r = round(wind)
        gust_r = round(gust)
        # "12g18kt" if gust meaningfully > wind, else "12kt"
        wind_label = (f"{wind_r}g{gust_r}kt"
                      if gust_r >= wind_r + 3 else f"{wind_r}kt")
        if wave_ft is not None and wave_ft >= 0.1:
            wind_label = f"{wind_label} · {wave_ft}ft"
        day = {
            "wind_kt_max": round(wind, 1),
            "gust_kt_max": round(gust, 1),
            "wave_ft_max": wave_ft,
            "temp_f": [round(tmin), round(tmax)],
            "precip": precip,
            "hazards": sorted({a["token"] for a in day_alerts}),
            "alerts": day_alerts,
        }
        day["icons"] = _planner_weather_icons(day)
        day["temp_label"] = f"{day['temp_f'][0]}–{day['temp_f'][1]}°"
        day["wind_label"] = wind_label
        out[date_] = day
    return out


def cmd_planner_publish(args, state):
    iteration = _resolve_iteration(args.iteration)
    start = datetime.fromisoformat(iteration["startDate"])
    duration = iteration.get("duration") or 7

    list_args = argparse.Namespace(
        iteration=args.iteration,
        labels=None, milestone=None, with_body=False,
        schedulable=False, limit=300,
    )
    items = _list_by_iteration(list_args)

    today = datetime.now(timezone.utc)
    cal_by_date: dict[str, list[dict]] = {}
    for ev in _load_calendar():
        cal_by_date.setdefault(ev["date"], []).append(
            {"label": ev["label"], "blocks": ev.get("blocks", True)}
        )

    window_dates = {
        (start + timedelta(days=i)).strftime("%Y-%m-%d")
        for i in range(duration)
    }
    if args.no_weather:
        weather_by_date: dict[str, dict] = {}
    else:
        weather_by_date = _planner_weather_for_window(state, sorted(window_dates))
    by_day: dict[str, list[dict]] = {}
    unscheduled: list[dict] = []
    for it in items:
        pi = _planner_issue(it)
        d = pi["day"]
        if d and d in window_dates:
            by_day.setdefault(d, []).append(pi)
        else:
            unscheduled.append(pi)

    days = []
    for i in range(duration):
        d = start + timedelta(days=i)
        date_str = d.strftime("%Y-%m-%d")
        day_issues = by_day.get(date_str, [])
        lanes: dict[str, list[dict]] = {s: [] for s in PLANNER_LANE_ORDER}
        for issue in day_issues:
            primary = _primary_system(issue["systems"])
            lanes.setdefault(primary, []).append(issue)
        # drop empty lanes for compactness
        lanes_compact = [
            {"system": s, "issues": lanes[s]}
            for s in PLANNER_LANE_ORDER
            if lanes.get(s)
        ]
        days.append({
            "date": date_str,
            "label": _day_label(d, today),
            "events": cal_by_date.get(date_str, []),
            "weather": weather_by_date.get(date_str),
            "lanes": lanes_compact,
            "task_count": len(day_issues),
        })

    payload = {
        "iteration": {
            "title": iteration["title"],
            "start_date": start.strftime("%Y-%m-%d"),
            "end_date": (start + timedelta(days=duration)).strftime("%Y-%m-%d"),
            "duration": duration,
        },
        "generated_at": now_iso(),
        "lane_order": PLANNER_LANE_ORDER,
        "days": days,
        "unscheduled": unscheduled,
    }

    PLANNER_DATA_FILE.parent.mkdir(parents=True, exist_ok=True)
    atomic_write_bytes(PLANNER_DATA_FILE, (json.dumps(payload, indent=2) + "\n").encode())
    print(f"wrote {PLANNER_DATA_FILE} "
          f"({len(items)} issues, {len(unscheduled)} unscheduled, "
          f"iteration {iteration['title']})")

    if args.commit or args.push:
        rel = PLANNER_DATA_FILE.relative_to(REPO_ROOT)
        cwd = str(REPO_ROOT)
        st = subprocess.run(["git", "status", "--porcelain", str(rel)],
                            capture_output=True, text=True, cwd=cwd)
        if not st.stdout.strip():
            print("planner: no changes to commit")
            return
        subprocess.run(["git", "add", str(rel)], check=True, cwd=cwd)
        msg = f"planner: refresh data/planner.json ({iteration['title']})"
        subprocess.run(["git", "commit", "-m", msg], check=True, cwd=cwd)
        print(f"committed: {msg}")
        if args.push:
            subprocess.run(["git", "push"], check=True, cwd=cwd)
            print("pushed")


# --- weather ---------------------------------------------------------------

TIDE_STATIONS_CACHE = DEFIANT_HOME / "tide-stations.json"
TIDE_STATIONS_TTL = timedelta(days=30)
USER_AGENT = "defiant/0.1 (ethan@knox.dev)"

# Closed vocabulary: NWS event names → defiant hazard tokens. Anything not in
# this map is dropped — agent matches strings, never parses descriptions.
HAZARDS = {
    "Small Craft Advisory":          "small_craft_advisory",
    "Special Marine Warning":        "special_marine_warning",
    "Marine Weather Statement":      "marine_weather_statement",
    "Gale Warning":                  "gale_warning",
    "Storm Warning":                 "storm_warning",
    "Hurricane Warning":             "hurricane_warning",
    "Hurricane Watch":               "hurricane_watch",
    "Tropical Storm Warning":        "tropical_storm_warning",
    "Tropical Storm Watch":          "tropical_storm_watch",
    "Severe Thunderstorm Warning":   "thunderstorms",
    "Severe Thunderstorm Watch":     "thunderstorms",
    "Tornado Warning":               "tornado",
    "Tornado Watch":                 "tornado",
    "Coastal Flood Warning":         "coastal_flood",
    "Coastal Flood Watch":           "coastal_flood",
    "Coastal Flood Advisory":        "coastal_flood",
    "High Wind Warning":             "high_wind",
    "Wind Advisory":                 "wind_advisory",
    "Heavy Freezing Spray Warning":  "freezing_spray",
    "Freezing Spray Advisory":       "freezing_spray",
    "Freeze Warning":                "freeze",
    "Hard Freeze Warning":           "freeze",
    "Frost Advisory":                "frost",
    "Dense Fog Advisory":            "fog",
    "Freezing Fog Advisory":         "fog",
    "Dense Smoke Advisory":          "smoke",
    "Heat Advisory":                 "heat",
    "Excessive Heat Warning":        "heat",
}


def http_json(url: str, *, accept: str | None = None) -> dict:
    headers = {"User-Agent": USER_AGENT}
    if accept:
        headers["Accept"] = accept
    req = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=20) as r:
            return json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        die(f"http {e.code} {url}: {e.read().decode()[:200]}")
    except urllib.error.URLError as e:
        die(f"network error {url}: {e}")


def fetch_forecast(lat: float, lon: float, days: int) -> dict:
    url = "https://api.open-meteo.com/v1/forecast?" + urlencode({
        "latitude": lat, "longitude": lon,
        "daily": ",".join([
            "wind_speed_10m_max", "wind_gusts_10m_max",
            "temperature_2m_max", "temperature_2m_min",
            "precipitation_sum",
        ]),
        "wind_speed_unit": "kn",
        "temperature_unit": "fahrenheit",
        "precipitation_unit": "inch",
        "forecast_days": days,
        "timezone": "auto",
    })
    return http_json(url)


def fetch_marine(lat: float, lon: float, days: int) -> dict | None:
    url = "https://marine-api.open-meteo.com/v1/marine?" + urlencode({
        "latitude": lat, "longitude": lon,
        "daily": "wave_height_max",
        "forecast_days": days,
        "timezone": "auto",
    })
    try:
        return http_json(url)
    except SystemExit:
        # marine API errors when point is too far inland — fall back gracefully
        return None


def fetch_alerts(lat: float, lon: float) -> list[dict]:
    url = f"https://api.weather.gov/alerts/active?point={lat},{lon}"
    return http_json(url, accept="application/geo+json").get("features", [])


def load_tide_stations() -> list[dict]:
    if TIDE_STATIONS_CACHE.exists():
        mtime = datetime.fromtimestamp(TIDE_STATIONS_CACHE.stat().st_mtime, tz=timezone.utc)
        if datetime.now(timezone.utc) - mtime < TIDE_STATIONS_TTL:
            with TIDE_STATIONS_CACHE.open() as f:
                return json.load(f)
    url = ("https://api.tidesandcurrents.noaa.gov/mdapi/prod/webapi/"
           "stations.json?type=tidepredictions")
    raw = http_json(url).get("stations", [])
    stations = [{"id": s["id"], "name": s["name"],
                 "lat": float(s["lat"]), "lon": float(s["lng"])}
                for s in raw if s.get("lat") is not None and s.get("lng") is not None]
    atomic_write_bytes(TIDE_STATIONS_CACHE, json.dumps(stations).encode())
    return stations


def haversine_km(lat1: float, lon1: float, lat2: float, lon2: float) -> float:
    R = 6371.0
    p1, p2 = math.radians(lat1), math.radians(lat2)
    dp = math.radians(lat2 - lat1)
    dl = math.radians(lon2 - lon1)
    a = math.sin(dp / 2) ** 2 + math.cos(p1) * math.cos(p2) * math.sin(dl / 2) ** 2
    return 2 * R * math.asin(math.sqrt(a))


def nearest_tide_station(lat: float, lon: float, max_km: float = 100) -> dict | None:
    stations = load_tide_stations()
    nearest = min(stations, key=lambda s: haversine_km(lat, lon, s["lat"], s["lon"]))
    if haversine_km(lat, lon, nearest["lat"], nearest["lon"]) > max_km:
        return None
    return nearest


def fetch_tides(lat: float, lon: float, days: int) -> tuple[list[dict], dict | None]:
    """Return (per-day high/low list, station meta) or ([], None) if no station nearby."""
    station = nearest_tide_station(lat, lon)
    if not station:
        return [], None
    url = "https://api.tidesandcurrents.noaa.gov/api/prod/datagetter?" + urlencode({
        "product": "predictions",
        "station": station["id"],
        "date": "today",
        "range": str(days * 24),
        "interval": "hilo",
        "datum": "MLLW",
        "time_zone": "lst_ldt",
        "units": "english",
        "format": "json",
    })
    data = http_json(url)
    by_date: dict[str, dict[str, list[str]]] = {}
    for p in data.get("predictions", []):
        date_, time_ = p["t"].split(" ")
        slot = by_date.setdefault(date_, {"high": [], "low": []})
        slot["high" if p["type"] == "H" else "low"].append(time_[:5])
    return [{"date": d, **v} for d, v in sorted(by_date.items())], station


def derive_satisfies(wind_kt: float, wave_ft: float | None,
                     precip: bool, temp_min: float, temp_max: float) -> list[str]:
    """Per .claude/skills/plan-iteration/SKILL.md vocabulary:
       any (always) / dry (no rain, ≤20kt) / warm (>65F, dry) / calm (≤10kt, <2ft, dry, mild)."""
    s = ["any"]
    if not precip and wind_kt <= 20:
        s.append("dry")
    if not precip and wind_kt <= 20 and temp_max > 65:
        s.append("warm")
    calm_wave = wave_ft is None or wave_ft < 2
    if not precip and wind_kt <= 10 and calm_wave and temp_min >= 40:
        s.append("calm")
    return s


def hazards_for_day(alerts: list[dict], date_str: str) -> list[str]:
    return sorted({a["token"] for a in alerts_for_day(alerts, date_str)})


def alerts_for_day(alerts: list[dict], date_str: str) -> list[dict]:
    """Return [{token, event, headline, url}] for alerts active on date_str (UTC).
    Filters to events present in HAZARDS — same closed vocabulary as hazards_for_day."""
    out: list[dict] = []
    seen: set[str] = set()
    day_start = datetime.fromisoformat(date_str).replace(tzinfo=timezone.utc)
    day_end = day_start + timedelta(days=1)
    for a in alerts:
        prop = a.get("properties", {})
        event = prop.get("event") or ""
        token = HAZARDS.get(event)
        if not token:
            continue
        try:
            eff = datetime.fromisoformat(prop["effective"])
            exp = datetime.fromisoformat(prop["expires"])
        except (KeyError, ValueError):
            continue
        if exp < day_start or eff > day_end:
            continue
        if token in seen:
            continue
        seen.add(token)
        out.append({
            "token": token,
            "event": event,
            "headline": prop.get("headline") or event,
            "tooltip": HAZARD_TOOLTIPS.get(token, prop.get("headline") or event),
            "url": prop.get("@id") or a.get("id") or prop.get("id"),
        })
    return out


def cmd_weather(args, state):
    lat = state.get("location", {}).get("lat")
    lon = state.get("location", {}).get("lon")
    if lat is None or lon is None:
        die("location not set; `defiant state set location.lat <X>` "
            "and `defiant state set location.lon <Y>` first")

    days_n = max(1, min(args.days, 16))
    fc = fetch_forecast(lat, lon, days_n)
    marine = fetch_marine(lat, lon, days_n)
    alerts = fetch_alerts(lat, lon)

    daily = fc["daily"]
    waves = (marine or {}).get("daily", {}).get("wave_height_max") or [None] * len(daily["time"])

    days = []
    for i, date_ in enumerate(daily["time"]):
        wind = daily["wind_speed_10m_max"][i] or 0
        gust = daily["wind_gusts_10m_max"][i] or 0
        tmax = daily["temperature_2m_max"][i]
        tmin = daily["temperature_2m_min"][i]
        precip = (daily["precipitation_sum"][i] or 0) >= 0.01
        wave_m = waves[i] if i < len(waves) else None
        wave_ft = round(wave_m * 3.28084, 1) if wave_m is not None else None
        days.append({
            "date": date_,
            "wind_kt_max": round(wind, 1),
            "gust_kt_max": round(gust, 1),
            "wave_ft_max": wave_ft,
            "temp_f": [round(tmin), round(tmax)],
            "precip": precip,
            "satisfies": derive_satisfies(wind, wave_ft, precip, tmin, tmax),
            "hazards": hazards_for_day(alerts, date_),
        })

    out = {
        "location": state.get("location", {}).get("name") or f"{lat:.4f},{lon:.4f}",
        "lat": lat,
        "lon": lon,
        "as_of": now_iso(),
        "days": days,
    }
    if marine is None:
        out["marine_note"] = "no marine wave data for this point (likely inland)"

    underway = state.get("mode", {}).get("status") == "underway"
    if underway and not args.no_tides:
        tides, station = fetch_tides(lat, lon, days_n)
        if tides:
            out["tides"] = tides
            out["tide_station"] = {"id": station["id"], "name": station["name"]}
        else:
            out["tides_note"] = "no tide station within 100km of location"

    json.dump(out, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")


# --- wiki ------------------------------------------------------------------

WIKI_REMOTE = "https://github.com/norton120/svdefiant.wiki.git"
DEFAULT_WIKI_DIR = DEFIANT_HOME / "wiki"


def wiki_dir() -> Path:
    return Path(os.environ.get("DEFIANT_WIKI", DEFAULT_WIKI_DIR))


def ensure_wiki() -> Path:
    d = wiki_dir()
    if (d / ".git").is_dir():
        return d
    if d.exists() and any(d.iterdir()):
        die(f"{d} exists but is not a git checkout; remove it or set DEFIANT_WIKI")
    d.parent.mkdir(parents=True, exist_ok=True)
    print(f"cloning {WIKI_REMOTE} → {d}", file=sys.stderr)
    try:
        r = subprocess.run(["git", "clone", "--quiet", WIKI_REMOTE, str(d)],
                           capture_output=True, text=True)
    except FileNotFoundError:
        die("git not installed")
    if r.returncode != 0:
        die(f"git clone failed:\n{r.stderr.strip() or r.stdout.strip()}")
    return d


def git_in(d: Path, *args: str) -> subprocess.CompletedProcess:
    r = subprocess.run(["git", "-C", str(d), *args], capture_output=True, text=True)
    if r.returncode != 0:
        die(f"git {' '.join(args[:2])}… failed:\n"
            f"{r.stderr.strip() or r.stdout.strip()}")
    return r


def page_path(d: Path, page: str) -> Path:
    name = page if page.endswith(".md") else f"{page}.md"
    return d / name


def cmd_wiki_search(args):
    d = ensure_wiki()
    flags = 0 if any(c.isupper() for c in args.query) else re.IGNORECASE
    try:
        pattern = re.compile(args.query, flags)
    except re.error as e:
        die(f"invalid regex {args.query!r}: {e}")

    matches: list[dict] = []
    for path in sorted(d.rglob("*.md")):
        if ".git" in path.parts:
            continue
        try:
            text = path.read_text(errors="replace")
        except OSError:
            continue
        for lineno, line in enumerate(text.splitlines(), 1):
            if not pattern.search(line):
                continue
            snippet = line.strip()
            if len(snippet) > 200:
                snippet = snippet[:200] + "…"
            matches.append({
                "page": str(path.relative_to(d)).removesuffix(".md"),
                "line": lineno,
                "snippet": snippet,
            })
            if len(matches) >= args.limit:
                break
        if len(matches) >= args.limit:
            break
    json.dump(matches, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")


def cmd_wiki_show(args):
    d = ensure_wiki()
    p = page_path(d, args.page)
    if not p.exists():
        die(f"page not found: {p.relative_to(d)}")
    text = p.read_text()
    sys.stdout.write(text)
    if not text.endswith("\n"):
        sys.stdout.write("\n")


def _wiki_push(d: Path, token: str) -> None:
    """Push HEAD:master via a token-in-URL one-shot remote. Token never
    touches disk — it's only in subprocess argv (visible to the local user
    via /proc, never serialized). Errors are redacted before display."""
    url = WIKI_REMOTE.replace("https://", f"https://x-access-token:{token}@")
    r = subprocess.run(
        ["git", "-C", str(d), "push", "--quiet", url, "HEAD:master"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        err = (r.stderr or r.stdout).replace(token, "***").strip()
        die(f"git push failed:\n{err}")


def cmd_wiki_edit(args):
    d = ensure_wiki()

    # Fail fast if we won't be able to push, so we don't leave a local commit
    # ahead of remote.
    token = os.environ.get("GH_TOKEN") or os.environ.get("GITHUB_TOKEN")
    if not token:
        die("GH_TOKEN (or GITHUB_TOKEN) env var required to push wiki edits — "
            "scope it to Contents:RW on norton120/svdefiant")

    porcelain = git_in(d, "status", "--porcelain").stdout
    if porcelain.strip():
        die(f"wiki has uncommitted changes:\n{porcelain}resolve before editing")

    git_in(d, "pull", "--ff-only", "--quiet")

    body_src = Path(args.body_file)
    if not body_src.exists():
        die(f"--body-file not found: {body_src}")
    body = body_src.read_text()
    if not body.endswith("\n"):
        body += "\n"

    p = page_path(d, args.page)
    new = not p.exists()
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(body)

    rel = str(p.relative_to(d))
    git_in(d, "add", rel)
    diff = git_in(d, "diff", "--cached", "--name-only").stdout.strip()
    if not diff:
        print(f"no changes to {rel}")
        return

    verb = "create" if new else "edit"
    git_in(d, "commit", "-m", f"agent: {verb} {p.stem}")
    _wiki_push(d, token)
    print(f"{verb}d {rel}")


# --- image -----------------------------------------------------------------

GH_REMOTE = "https://github.com/norton120/svdefiant.git"
STATIC_IMAGES_DIR = REPO_ROOT / "static" / "images"
IMG_MAX_DIM = 2400
IMG_JPEG_QUALITY = 85
IMG_NAME_RE = re.compile(r"[^a-z0-9._-]+")


def _sanitize_image_name(name: str) -> str:
    base = name.strip().lower().replace(" ", "-")
    # strip any extension the caller included; we always emit .jpg
    base = re.sub(r"\.(jpe?g|png|heic|heif|webp|gif|tiff?)$", "", base)
    base = IMG_NAME_RE.sub("-", base)
    base = re.sub(r"-+", "-", base).strip("-._")
    if not base or not re.search(r"[a-z0-9]", base):
        die("image name must contain at least one alphanumeric character")
    return base


def _optimize_to_jpeg(src: Path, dst: Path) -> None:
    from PIL import Image, ImageOps
    try:
        import pillow_heif  # type: ignore
        pillow_heif.register_heif_opener()
    except ImportError:
        pass

    try:
        im = Image.open(src)
    except Exception as e:
        die(f"could not read image: {e}")

    with im:
        im = ImageOps.exif_transpose(im)
        im.thumbnail((IMG_MAX_DIM, IMG_MAX_DIM), Image.LANCZOS)
        if im.mode in ("RGBA", "LA"):
            bg = Image.new("RGB", im.size, (255, 255, 255))
            bg.paste(im, mask=im.split()[-1])
            im = bg
        elif im.mode != "RGB":
            im = im.convert("RGB")
        dst.parent.mkdir(parents=True, exist_ok=True)
        im.save(dst, format="JPEG", quality=IMG_JPEG_QUALITY,
                optimize=True, progressive=True)


def _repo_push(token: str, branch: str = "main") -> None:
    """Push HEAD:<branch> via a token-in-URL one-shot remote — same scheme as
    _wiki_push (token never serialized; redacted from error output)."""
    url = GH_REMOTE.replace("https://", f"https://x-access-token:{token}@")
    r = subprocess.run(
        ["git", "-C", str(REPO_ROOT), "push", "--quiet", url, f"HEAD:{branch}"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        err = (r.stderr or r.stdout).replace(token, "***").strip()
        die(f"git push failed:\n{err}")


def cmd_image_add(args):
    token = os.environ.get("GH_TOKEN") or os.environ.get("GITHUB_TOKEN")
    if not token and not args.no_push:
        die("GH_TOKEN (or GITHUB_TOKEN) env var required to push image — "
            "scope it to Contents:RW on norton120/svdefiant "
            "(or pass --no-push for local testing)")

    src = Path(args.file)
    if not src.exists():
        die(f"--file not found: {src}")

    name = _sanitize_image_name(args.name)
    dst = STATIC_IMAGES_DIR / f"{name}.jpg"

    if not args.no_push:
        porcelain = git_in(REPO_ROOT, "status", "--porcelain").stdout
        if porcelain.strip():
            die(f"repo has uncommitted changes:\n{porcelain}"
                "resolve before adding image")
        git_in(REPO_ROOT, "pull", "--ff-only", "--quiet")

    if dst.exists():
        die(f"image already exists: static/images/{name}.jpg "
            "(rename or remove the existing file first)")

    _optimize_to_jpeg(src, dst)

    rel = str(dst.relative_to(REPO_ROOT))
    if args.no_push:
        print(json.dumps({
            "ok": True,
            "filename": dst.name,
            "path": rel,
            "url": f"https://svdefiant.com/images/{dst.name}",
            "pushed": False,
        }))
        return

    git_in(REPO_ROOT, "add", rel)
    diff = git_in(REPO_ROOT, "diff", "--cached", "--name-only").stdout.strip()
    if not diff:
        # Should be unreachable (we just wrote the file and it's a new path),
        # but bail cleanly if so.
        die(f"no changes staged for {rel}")
    git_in(REPO_ROOT, "commit", "-m", f"agent: add image {name}")
    _repo_push(token)

    print(json.dumps({
        "ok": True,
        "filename": dst.name,
        "path": rel,
        "url": f"https://svdefiant.com/images/{dst.name}",
        "pushed": True,
    }))


# --- main ------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="defiant",
        description=__doc__.split("\n", 1)[0],
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="State + ack files live under DEFIANT_HOME (default ~/.defiant).",
    )
    nouns = p.add_subparsers(dest="noun", required=True)

    # --- state ---
    state = nouns.add_parser("state", help="boat state (location, mode)")
    state.set_defaults(func=cmd_state_show, needs_state=True)
    sv = state.add_subparsers(dest="verb")

    sv_show = sv.add_parser("show", help="show all state (default)")
    sv_show.set_defaults(func=cmd_state_show, needs_state=True)

    sv_get = sv.add_parser("get", help="get one section or field, e.g. mode.status")
    sv_get.add_argument("key", help="section or section.field")
    sv_get.set_defaults(func=cmd_state_get, needs_state=True)

    sv_set = sv.add_parser("set", help="set one field; auto-bumps section.updated")
    sv_set.add_argument("key", help="section.field, e.g. mode.status")
    sv_set.add_argument("value")
    sv_set.set_defaults(func=cmd_state_set, needs_state=True)

    sv_stale = sv.add_parser("stale", help="exit nonzero if any watched section is stale")
    sv_stale.add_argument("--max", default="3d", help="max age (NNd|NNh|NNm), default 3d")
    sv_stale.set_defaults(func=cmd_state_stale, needs_state=True)

    # --- inbox ---
    inbox = nouns.add_parser("inbox", help="SES inbound mail")
    iv = inbox.add_subparsers(dest="verb")

    iv_list = iv.add_parser("list", help="list messages (default: unprocessed only)")
    iv_list.add_argument("--since", default="14d", help="default 14d")
    iv_list.add_argument("--from", dest="from_pat", help="regex on From header")
    iv_list.add_argument("--subject", dest="subject_pat", help="regex on Subject")
    g = iv_list.add_mutually_exclusive_group()
    g.add_argument("--unprocessed", action="store_true", default=True,
                   help="exclude acked messages (default)")
    g.add_argument("--all", dest="unprocessed", action="store_false",
                   help="include acked messages")
    iv_list.set_defaults(func=cmd_inbox_list)
    inbox.set_defaults(func=cmd_inbox_list, since="14d", from_pat=None,
                       subject_pat=None, unprocessed=True)

    iv_get = iv.add_parser("get", help="full message body + attachments")
    iv_get.add_argument("id", help="Message-ID or s3 key (substring ok)")
    iv_get.set_defaults(func=cmd_inbox_get)

    iv_ack = iv.add_parser("ack", help="mark processed; won't appear in `list` again")
    iv_ack.add_argument("id", help="Message-ID or s3 key (use the value from `list`)")
    iv_ack.add_argument("--note", help="why you acked it (for debugging)")
    iv_ack.set_defaults(func=cmd_inbox_ack)

    iv_unack = iv.add_parser("unack", help="undo a previous ack")
    iv_unack.add_argument("id")
    iv_unack.set_defaults(func=cmd_inbox_unack)

    # --- task ---
    task = nouns.add_parser("task", help="GitHub issues + Project v2")
    tv = task.add_subparsers(dest="verb")

    tv_list = tv.add_parser("list", help="open issues, pre-summarized")
    tv_list.add_argument("--milestone", help="filter by milestone title")
    tv_list.add_argument("--label", dest="labels", action="append",
                         help="filter by label (repeatable)")
    tv_list.add_argument("--limit", type=int, default=300)
    tv_list.add_argument("--with-body", action="store_true",
                         help="include issue body in each item (for triage/matching)")
    tv_list.add_argument("--schedulable", action="store_true",
                         help="apply boat-mode filter (excludes blocked:parts; "
                              "underway → loc:underway-ok only; not-docked → drops "
                              "loc:dockside-only)")
    tv_list.add_argument("--iteration",
                         help="restrict to a project iteration: 'current', "
                              "'next', or a literal iteration ID. Adds "
                              "iteration/day/project_status to each item.")
    tv_list.set_defaults(func=cmd_task_list, needs_state=True)

    tv_show = tv.add_parser("show", help="full issue + project status + iteration")
    tv_show.add_argument("num", type=int)
    tv_show.set_defaults(func=cmd_task_show)

    def _add_label_args(sp, *, allow_remove_blocked: bool):
        sp.add_argument("-p", "--priority", choices=LABEL_PRIORITIES)
        sp.add_argument("-s", "--system", choices=LABEL_SYSTEMS)
        sp.add_argument("-l", "--location",
                        help=f"comma-list from {{{','.join(LABEL_LOCATIONS)}}}")
        sp.add_argument("-e", "--energy", choices=LABEL_ENERGIES)
        sp.add_argument("-w", "--weather", choices=LABEL_WEATHERS)
        sp.add_argument("-t", "--time", dest="time_", choices=LABEL_TIMES)
        sp.add_argument("-b", "--body")
        sp.add_argument("--body-file")
        bp = sp.add_mutually_exclusive_group()
        bp.add_argument("--blocked-parts", dest="blocked_parts",
                        action="store_const", const="add",
                        help="add blocked:parts label")
        if allow_remove_blocked:
            bp.add_argument("--no-blocked-parts", dest="blocked_parts",
                            action="store_const", const="remove",
                            help="remove blocked:parts label")
        sp.set_defaults(blocked_parts=None)

    tv_create = tv.add_parser("create", help="open new issue + add to project")
    tv_create.add_argument("title")
    _add_label_args(tv_create, allow_remove_blocked=False)
    tv_create.set_defaults(func=cmd_task_create)

    tv_update = tv.add_parser("update", help="patch labels/body; idempotent dim replace")
    tv_update.add_argument("num", type=int)
    _add_label_args(tv_update, allow_remove_blocked=True)
    tv_update.set_defaults(func=cmd_task_update)

    tv_close = tv.add_parser("close", help="close issue")
    tv_close.add_argument("num", type=int)
    tv_close.add_argument("--reason", choices=("completed", "not planned"))
    tv_close.set_defaults(func=cmd_task_close)

    tv_iter = tv.add_parser("iteration", help="assign issue to project iteration")
    tv_iter.add_argument("num", type=int)
    g = tv_iter.add_mutually_exclusive_group(required=True)
    g.add_argument("--current", action="store_true", help="this week's iteration")
    g.add_argument("--next", dest="next", action="store_true",
                   help="the iteration after the current one")
    g.add_argument("--id", help="literal iteration ID (e.g. c1d92a83)")
    tv_iter.set_defaults(func=cmd_task_iteration)

    tv_day = tv.add_parser("day", help="set the project Target date (per-issue day)")
    tv_day.add_argument("num", type=int)
    tv_day.add_argument("date", nargs="?", help="YYYY-MM-DD")
    tv_day.add_argument("--clear", action="store_true",
                        help="clear the day field on this issue")
    tv_day.set_defaults(func=cmd_task_day)

    # --- calendar ---
    cal = nouns.add_parser("calendar", help="day-level events that block/colour scheduling")
    cv = cal.add_subparsers(dest="verb")

    cv_add = cv.add_parser("add", help="add or overwrite an event on a date")
    cv_add.add_argument("date", help="YYYY-MM-DD")
    cv_add.add_argument("label")
    cv_add.add_argument("--soft", action="store_true",
                        help="appears on the planner but doesn't block scheduling "
                             "(default: blocks)")
    cv_add.set_defaults(func=cmd_calendar_add)

    cv_rm = cv.add_parser("remove", help="remove the event on a date (if any)")
    cv_rm.add_argument("date", help="YYYY-MM-DD")
    cv_rm.set_defaults(func=cmd_calendar_remove)

    cv_list = cv.add_parser("list", help="list events in a date window (default today + 7d)")
    cv_list.add_argument("--from", dest="from_", help="YYYY-MM-DD (default: today)")
    cv_list.add_argument("--to", help="YYYY-MM-DD (default: today + 7d)")
    cv_list.set_defaults(func=cmd_calendar_list)

    # --- planner ---
    planner = nouns.add_parser("planner", help="build data/planner.json from current iteration")
    pv = planner.add_subparsers(dest="verb")

    pv_pub = pv.add_parser("publish", help="render data/planner.json (optionally commit/push)")
    pv_pub.add_argument("--iteration", default="current",
                        help="iteration spec: 'current' (default), 'next', or literal ID")
    pv_pub.add_argument("--commit", action="store_true",
                        help="git add + commit data/planner.json after writing")
    pv_pub.add_argument("--push", action="store_true",
                        help="implies --commit; also git push")
    pv_pub.add_argument("--no-weather", action="store_true",
                        help="skip weather fetch (offline / no location set)")
    pv_pub.set_defaults(func=cmd_planner_publish, needs_state=True)

    # --- weather ---
    weather = nouns.add_parser("weather", help="marine weather + tides (auto when underway)")
    weather.add_argument("--days", type=int, default=7,
                         help="forecast horizon, 1-16 (default 7)")
    weather.add_argument("--no-tides", action="store_true",
                         help="omit tides even when underway")
    weather.set_defaults(func=cmd_weather, needs_state=True)

    # --- wiki ---
    wiki = nouns.add_parser("wiki", help="local wiki search/edit (auto-clones on first use)")
    wv = wiki.add_subparsers(dest="verb")

    wv_search = wv.add_parser("search", help="regex search across wiki pages")
    wv_search.add_argument("query", help="regex (smart-case: lowercase = case-insensitive)")
    wv_search.add_argument("--limit", type=int, default=5)
    wv_search.set_defaults(func=cmd_wiki_search)

    wv_show = wv.add_parser("show", help="print a page's content")
    wv_show.add_argument("page", help="page name (with or without .md)")
    wv_show.set_defaults(func=cmd_wiki_show)

    wv_edit = wv.add_parser("edit", help="replace page contents, commit, push")
    wv_edit.add_argument("page")
    wv_edit.add_argument("--body-file", required=True,
                         help="path to a file containing the new page body")
    wv_edit.set_defaults(func=cmd_wiki_edit)

    # --- image ---
    image = nouns.add_parser("image", help="optimize + commit images to static/images/")
    iv_img = image.add_subparsers(dest="verb")

    iv_add = iv_img.add_parser(
        "add",
        help="optimize an image (≤2400px JPEG q85) and commit it to static/images/",
    )
    iv_add.add_argument("name", help="filename stem; sanitized to [a-z0-9._-], '.jpg' appended")
    iv_add.add_argument("--file", required=True,
                        help="path to the source image (jpg/png/heic/webp/...)")
    iv_add.add_argument("--no-push", action="store_true",
                        help="optimize + write only; skip git add/commit/push (for testing)")
    iv_add.set_defaults(func=cmd_image_add)

    return p


def main() -> None:
    p = build_parser()
    args = p.parse_args()
    if getattr(args, "func", None) is None:
        # noun parsed but no verb-default and no func — show that noun's help
        p.parse_args([args.noun, "--help"])
        return
    if getattr(args, "needs_state", False):
        args.func(args, load_state())
    else:
        args.func(args)


if __name__ == "__main__":
    main()
